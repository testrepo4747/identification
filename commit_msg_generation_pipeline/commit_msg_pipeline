# ---------------- Utility helpers ----------------
def first_existing_col(df: pd.DataFrame, candidates: List[str]) -> Optional[str]:
    for c in candidates:
        if c in df.columns:
            return c
    return None

def extract_json(text: str) -> Optional[str]:
    if not text:
        return None
    fence = re.search(r"```json\s*(\{[\s\S]*?\})\s*```", text, re.IGNORECASE)
    if fence:
        return fence.group(1).strip()
    starts = [m.start() for m in re.finditer(r"\{", text)]
    ends = [m.start() for m in re.finditer(r"\}", text)]
    if not starts or not ends:
        return None
    start = starts[0]
    end = ends[-1]
    if end > start:
        cand = text[start:end+1]
        cand = re.sub(r",\s*([}\]])", r"\1", cand)
        return cand
    return None

def safe_json_loads(s: Optional[str]) -> Optional[Dict[str, Any]]:
    if s is None:
        return None
    try:
        return json.loads(s)
    except Exception:
        s2 = re.sub(r",\s*([}\]])", r"\1", s)
        try:
            return json.loads(s2)
        except Exception:
            return None

def stringify_anchor(a: Any) -> Optional[str]:
    if isinstance(a, str):
        return a.strip() or None
    if isinstance(a, dict):
        if "line_span" in a and isinstance(a["line_span"], str):
            return a["line_span"].strip() or None
        if "file" in a and "lines" in a:
            f = str(a["file"]).strip()
            ln = str(a["lines"]).strip()
            if f and ln:
                return f"{f}:{ln}"
        return None
    if isinstance(a, (list, tuple)):
        try:
            s = ", ".join(map(str, a)).strip()
            return s or None
        except Exception:
            return None
    return str(a).strip() or None

def normalize_list_to_strings(x: Any) -> List[str]:
    if not isinstance(x, list):
        return []
    out, seen = [], set()
    for item in x:
        if isinstance(item, str):
            s = item.strip()
        elif isinstance(item, dict):
            s = json.dumps(item, ensure_ascii=False, sort_keys=True)
        elif isinstance(item, (list, tuple)):
            s = ", ".join(str(y) for y in item)
        else:
            s = str(item)
        s = s.strip()
        if s and s not in seen:
            seen.add(s); out.append(s)
    return out

def normalize_evidence_to_strings(evidence_list: Any) -> List[str]:
    if not isinstance(evidence_list, list):
        return []
    out, seen = [], set()
    for item in evidence_list:
        s = stringify_anchor(item)
        if s and s not in seen:
            seen.add(s); out.append(s)
    return out

def estimate_tokens(text: str, tokenizer) -> int:
    return len(tokenizer.encode(text, add_special_tokens=False))

